# Leave empty to use same-origin `/api` (Vite proxies `/api` → target in vite.config.ts).
# Point at remote API (OAuth uses VITE_API_ORIGIN when the API is on another host):
# VITE_API_BASE=https://khudrapasalserver.360winx.com/api
# VITE_API_ORIGIN=https://khudrapasalserver.360winx.com
# Local Django instead of vite.config proxy:
# VITE_API_BASE=http://127.0.0.1:8000/api
# VITE_API_ORIGIN=http://127.0.0.1:8000
# Google Identity Services web client id
# VITE_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
