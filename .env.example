# Leave empty to use same-origin `/api` (Vite proxies `/api` → target in vite.config.ts).
# Point at remote API (OAuth uses VITE_API_ORIGIN when the API is on another host):
# VITE_API_BASE=https://khudrapasalserver.360winx.com/api
# VITE_API_ORIGIN=https://khudrapasalserver.360winx.com
# Local Django instead of vite.config proxy (required for local "Continue with Google" — OAuth must hit Django;
# also use this to test `/api/ai-pitch/` before it exists on the remote API — set GEMINI_API_KEY in `server/.env`):
# VITE_API_BASE=http://127.0.0.1:8000/api
# VITE_API_ORIGIN=http://127.0.0.1:8000
# Register in Google Cloud Console redirect URI exactly:
#   http://127.0.0.1:8000/api/auth/social/google/callback/
# Google Identity Services web client id (same as API GOOGLE_OAUTH_CLIENT_ID)
# VITE_GOOGLE_CLIENT_ID=386184793784-xxxx.apps.googleusercontent.com
# Optional: override origin for family join share links when API `join_url` is absent (e.g. local UI + prod API).
# Production should set FRONTEND_URL (or BASE_URL) on the API so `/portal/family/join-share-link/` returns `join_url`.
# VITE_PUBLIC_APP_URL=https://khudrapasal.360winx.com
# Default post-login path for Google/Facebook OAuth and token callback (customer home; matches API REDIRECT_AFTER_LOGIN).
# VITE_REDIRECT_AFTER_LOGIN=/portal
#
# Firebase Cloud Messaging (web push) — VAPID key from Firebase Console → Project settings → Cloud Messaging → Web Push certificates.
# Optional overrides (defaults are built into `src/lib/firebaseWebConfig.ts`; keep `public/firebase-messaging-sw.js` in sync if you change project).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
# VITE_FIREBASE_VAPID_KEY=
